body {
	margin: 0;
	padding: 16px;
	background-color:#383940;
	color:#ffffff;
}
.center {
	display : flex;
	justify-content: center;
	align-items: center;	
}

.center-column{
	display:flex;
	flex-direction: column;
	align-items:center;
	gap:20px;
	width:100%;
	
}
.cell{
	background-color: #545561;
	color:#E0F9FF;
}

#board {
	display: grid;
	grid-template-rows: repeat(3, 1fr);
	grid-template-columns: repeat(3, 1fr);
	width: 100%;
	max-width: 380px;
	aspect-ratio: 1/1;
}

